{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD ./",
  "crons": [
    {
      "path": "/api/cron/analytics/daily",
      "schedule": "30 0 * * *"
    },
    {
      "path": "/api/cron/reports/export-jobs",
      "schedule": "*/2 * * * *"
    }
  ]
}
