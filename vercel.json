{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/analytics/daily",
      "schedule": "30 0 * * *"
    },
    {
      "path": "/api/cron/reports/export-jobs",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/inventory/rename-media",
      "schedule": "*/10 * * * *"
    }
  ]
}
